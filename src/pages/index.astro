---
import HomeLayout from "../layouts/HomeLayout.astro";
import { projects } from "../data/projects";

const personLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Leopoldo Lira",
  jobTitle: "Fullstack Developer",
  url: "https://liraleopoldo.dev",
  sameAs: [
    "https://www.linkedin.com/in/leopoldo-lira-b70b52116/",
    "https://github.com/LeopoldoLira",
  ],
});

const stack = [
  { src: "/svgs/react.svg", label: "React" },
  { src: "/svgs/ts.svg", label: "TypeScript" },
  { src: "/svgs/js.svg", label: "JavaScript" },
  { src: "/svgs/tailwind.svg", label: "Tailwind" },
  { src: "/svgs/astro.svg", label: "Astro" },
  { src: "/svgs/html.svg", label: "HTML" },
  { src: "/svgs/css.svg", label: "CSS" },
  { src: "/svgs/sass.svg", label: "Sass" },
  { src: "/svgs/jest.svg", label: "Jest" },
  { src: "/svgs/node.svg", label: "Node.js" },
  { src: "/svgs/express.svg", label: "Express" },
  { src: "/svgs/python.svg", label: "Python" },
  { src: "/svgs/django.svg", label: "Django" },
  { src: "/svgs/mysql.svg", label: "MySQL" },
  { src: "/svgs/aws.svg", label: "AWS" },
  { src: "/svgs/docker.svg", label: "Docker" },
  { src: "/svgs/wordpress.svg", label: "WordPress" },
  { src: "/svgs/figma.svg", label: "Figma" },
];

const featured = projects.find((p) => p.featured) ?? projects[0];
---

<HomeLayout title="Fullstack Developer | Leopoldo Lira">
  <script type="application/ld+json" is:inline set:html={personLd} slot="head" />

  <!-- ============ Hero ============ -->
  <section class="relative flex min-h-dvh flex-col justify-center">
    <div class="mx-auto w-full max-w-[1600px] px-sm pb-xl pt-2xl md:px-lg">
      <!-- status line -->
      <p class="flex flex-wrap items-center gap-x-sm gap-y-xs font-mono text-xs text-text-secondary">
        <span>fullstack developer</span>
        <span class="text-border-strong" aria-hidden="true">/</span>
        <span>working worldwide</span>
        <span class="text-border-strong" aria-hidden="true">/</span>
        <span class="flex items-center gap-xs text-accent">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
          available
        </span>
      </p>

      <!-- headline -->
      <h1 class="mt-md max-w-[18ch] font-display text-[clamp(1.55rem,1rem+2.6vw,2.9rem)] font-semibold leading-[1.12] tracking-[-0.01em] text-text-primary">
        I turn product ideas into software <span class="text-accent">teams can trust</span> in production.
      </h1>

      <!-- subheadline -->
      <p class="mt-md max-w-[62ch] text-base leading-relaxed text-text-secondary md:text-lg">
        Over five years of production WordPress work, comfortable building across
        Django and React and collaborating with teams around the world. Now bringing
        that reliability to a product team.
      </p>

      <!-- CTAs -->
      <div class="mt-lg flex flex-wrap items-center gap-sm">
        <a
          href="#work"
          class="inline-flex min-h-[44px] items-center justify-center gap-xs rounded-md bg-accent px-md py-xs font-mono text-sm font-semibold text-background transition-colors hover:bg-accent-bright"
        >
          see my work
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <polyline points="19 12 12 19 5 12"></polyline>
          </svg>
        </a>
        <a
          href="mailto:lira.leopoldo97@gmail.com"
          class="inline-flex min-h-[44px] items-center justify-center rounded-md border border-border px-md py-xs font-mono text-sm text-text-primary transition-colors hover:border-accent hover:text-accent"
        >
          get in touch
        </a>
        <button
          type="button"
          data-cmdk-open
          class="inline-flex min-h-[44px] items-center gap-xs px-xs font-mono text-xs text-text-secondary transition-colors hover:text-text-primary"
        >
          or press
          <kbd class="inline-flex items-center gap-0.5 rounded border border-border-strong px-1 py-0.5 text-[0.7rem]">⌘K</kbd>
          to jump anywhere
        </button>
      </div>

      <!-- stack inventory -->
      <div class="mt-2xl">
        <p class="mono-label mb-md">stack</p>
        <ul class="flex flex-wrap gap-x-lg gap-y-md">
          {
            stack.map((tech) => (
              <li class="flex w-14 flex-col items-center gap-xs">
                <img
                  src={tech.src}
                  alt={`${tech.label} logo`}
                  width="32"
                  height="32"
                  loading="lazy"
                  class="stack-icon h-8 w-8"
                />
                <span class="text-center font-mono text-[0.65rem] leading-tight text-text-secondary">
                  {tech.label}
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- ============ Work (manifest + preview monitor) ============ -->
  <section id="work" class="scroll-mt-24 border-t border-border">
    <div class="mx-auto w-full max-w-[1600px] px-sm py-2xl md:px-lg">
      <header class="mb-lg flex items-baseline justify-between gap-sm">
        <div>
          <p class="mono-label">work</p>
          <h2 class="mt-xs font-display text-2xl font-semibold tracking-tight text-text-primary md:text-3xl">
            Selected work
          </h2>
        </div>
        <a href="/projects" class="font-mono text-xs text-text-secondary transition-colors hover:text-accent">
          all&nbsp;projects&nbsp;&#8250;
        </a>
      </header>

      <div class="grid gap-lg lg:grid-cols-[1.35fr_1fr]">
        <!-- Manifest -->
        <ul id="work-manifest" class="flex flex-col">
          {
            projects.map((project, i) => (
              <li>
                <a
                  href={`/projects/${project.slug}`}
                  class="manifest-row group -mx-sm grid grid-cols-[auto_1fr_auto] items-center gap-sm border-t border-border px-sm py-md transition-colors last:border-b hover:bg-accent-soft"
                  data-slug={project.slug}
                  data-preview={project.image}
                >
                  <span class="manifest-index font-mono text-xs text-text-secondary">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <span class="min-w-0">
                    <span class="flex items-center gap-xs">
                      <span class="font-display text-base font-semibold text-text-primary transition-colors group-hover:text-accent md:text-lg">
                        {project.title}
                      </span>
                      {project.featured && (
                        <span class="rounded-full bg-accent-soft px-2 py-0.5 font-mono text-[0.6rem] uppercase tracking-wider text-accent">
                          featured
                        </span>
                      )}
                    </span>
                    <span class="mt-1 block truncate font-mono text-xs text-text-secondary">
                      {project.techStack.join(" · ")}
                    </span>
                    <!-- inline thumbnail (mobile only) -->
                    <img
                      src={project.image}
                      alt=""
                      loading="lazy"
                      class="mt-sm block aspect-[16/9] w-full rounded-md border border-border object-cover object-top lg:hidden"
                    />
                  </span>
                  <span class="manifest-arrow font-mono text-text-secondary transition-all group-hover:translate-x-1 group-hover:text-accent" aria-hidden="true">
                    &#8250;
                  </span>
                </a>
              </li>
            ))
          }
        </ul>

        <!-- Preview monitor (desktop) -->
        <div class="hidden lg:block">
          <div id="work-preview" class="work-preview sticky top-24 overflow-hidden rounded-lg border border-border bg-surface">
            <div class="flex items-center gap-xs border-b border-border px-sm py-xs">
              <span class="h-2 w-2 rounded-full bg-border-strong" aria-hidden="true"></span>
              <span class="h-2 w-2 rounded-full bg-border-strong" aria-hidden="true"></span>
              <span class="h-2 w-2 rounded-full bg-border-strong" aria-hidden="true"></span>
              <span id="work-preview-name" class="ml-xs font-mono text-[0.7rem] text-text-secondary">{featured.slug}.png</span>
            </div>
            <div class="work-preview__stage relative aspect-[16/10]">
              {
                projects.map((project) => (
                  <img
                    class:list={["work-preview__img absolute inset-0 h-full w-full object-cover object-top", project.slug === featured.slug && "is-active"]}
                    data-slug={project.slug}
                    src={project.image}
                    alt=""
                    loading="lazy"
                  />
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ About ============ -->
  <section id="about" class="scroll-mt-24 border-t border-border">
    <div class="mx-auto w-full max-w-[1600px] px-sm py-2xl md:px-lg">
      <div class="grid grid-cols-1 gap-lg md:grid-cols-[1fr_1.4fr] md:gap-2xl">
        <div>
          <p class="mono-label">about</p>
          <h2 class="mt-xs font-display text-2xl font-semibold tracking-tight text-text-primary md:text-3xl">
            The short version
          </h2>
        </div>

        <div class="max-w-[68ch]">
          <div class="space-y-md text-base leading-relaxed text-text-secondary md:text-lg">
            <p>
              I'm Leopoldo, a fullstack developer. For the last five years I've
              shipped production WordPress work for clients and teams around the
              world, from brand sites to law firms to content platforms, and I build
              comfortably across Django and React too. Wherever the work comes from,
              I hold it to a global standard.
            </p>
            <p>
              I care about software that holds up: interfaces that stay clear as
              they grow, backends that don't surprise you at 2am, and code the next
              person can actually read. What I like most is being the person a team
              can hand an ambiguous problem to and trust it comes back solid.
            </p>
          </div>

          <div class="mt-lg">
            <p class="mono-label mb-sm">currently</p>
            <ul class="space-y-sm">
              {
                [
                  "Shipping with Next.js 15 and the App Router",
                  "Building a personal finance insights app",
                  "Confident delivering products on any stack",
                  "Open to fullstack and frontend roles at product teams",
                ].map((item) => (
                  <li class="flex gap-sm">
                    <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true" />
                    <span class="text-text-secondary">{item}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</HomeLayout>

<style>
  /* Stack: uniform monochrome logos in one soft off-white tone. The filter
     normalizes every SVG (fills or currentColor) to a single color, so the
     mixed dark/bright brand colors no longer matter on the dark background. */
  .stack-icon {
    filter: brightness(0) invert(0.85);
  }

  /* Work preview monitor: crossfade images driven by .is-active */
  .work-preview__img {
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .work-preview__img.is-active {
    opacity: 1;
  }
</style>

<script>
  function initWork() {
    const rows = document.querySelectorAll<HTMLElement>("#work-manifest .manifest-row");
    const imgs = document.querySelectorAll<HTMLElement>(".work-preview__img");
    const nameEl = document.getElementById("work-preview-name");
    if (rows.length === 0 || imgs.length === 0) return;

    const activate = (slug: string) => {
      imgs.forEach((img) => img.classList.toggle("is-active", img.dataset.slug === slug));
      if (nameEl) nameEl.textContent = `${slug}.png`;
    };

    rows.forEach((row) => {
      const slug = row.dataset.slug;
      if (!slug) return;
      row.addEventListener("mouseenter", () => activate(slug));
      row.addEventListener("focus", () => activate(slug));
    });
  }

  document.addEventListener("astro:page-load", initWork);
</script>
